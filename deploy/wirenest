#!/usr/bin/env bash
# WireNest 管理菜单。装到 /usr/local/bin/wirenest，直接运行 `wirenest` 调出菜单。
#   启动 / 停止 / 重启 / 更新 / 改端口 / 重置登录密码。
# 也支持直接子命令：wirenest {start|stop|restart|update|status}
set -uo pipefail

UNIT_NAME="wirenest"
UNIT="/etc/systemd/system/${UNIT_NAME}.service"
# Fall back to the legacy unit name for installs predating the rename.
if [[ ! -f "$UNIT" && -f "/etc/systemd/system/wireguard-ui.service" ]]; then
  UNIT_NAME="wireguard-ui"
  UNIT="/etc/systemd/system/wireguard-ui.service"
fi
BIN="/usr/local/bin/wireguard-ui"
DATA_DIR="/var/lib/wireguard-ui"
REPO="${WGUI_REPO:-alex021120/wirenest}"

c_reset=$'\033[0m'; c_bold=$'\033[1m'; c_y=$'\033[1;33m'; c_g=$'\033[1;32m'; c_r=$'\033[1;31m'; c_dim=$'\033[2m'

need_root() { [[ $EUID -eq 0 ]] || { echo "${c_r}请用 root 运行（sudo wirenest）${c_reset}" >&2; exit 1; }; }
pause()     { read -rp $'\n回车返回菜单… ' _; }

get_env() { sed -n "s/^Environment=${1}=//p" "$UNIT" 2>/dev/null | head -n1; }

# 安全地改写单元里某个 Environment=KEY=VALUE 行（不走 sed，避免特殊字符问题）。
set_env() {
  local key="$1" val="$2" tmp found=0
  tmp="$(mktemp)"
  while IFS= read -r line; do
    if [[ "$line" == "Environment=${key}="* ]]; then
      printf 'Environment=%s=%s\n' "$key" "$val"; found=1
    else
      printf '%s\n' "$line"
    fi
  done < "$UNIT" > "$tmp"
  [[ $found -eq 1 ]] || { rm -f "$tmp"; return 1; }
  cat "$tmp" > "$UNIT"; rm -f "$tmp"
}

server_ip() { curl -fsS --max-time 4 https://api.ip.sb/ip 2>/dev/null || hostname -I 2>/dev/null | awk '{print $1}'; }

print_status() {
  local active addr port ver
  active="$(systemctl is-active "$UNIT_NAME" 2>/dev/null)"
  addr="$(get_env WGUI_ADDR)"; port="${addr##*:}"
  ver="$([[ -x "$BIN" ]] && "$BIN" -version 2>/dev/null)"
  local dot text
  if [[ "$active" == "active" ]]; then dot="${c_g}●${c_reset}"; text="${c_g}运行中${c_reset}"; else dot="${c_r}●${c_reset}"; text="${c_r}${active:-未安装}${c_reset}"; fi
  printf '%s\n' "${c_bold}  WireNest 管理菜单${c_reset}  ${c_dim}${ver}${c_reset}"
  printf '  状态: %s %s   端口: %s\n' "$dot" "$text" "${port:-?}"
  printf '  %s面板: http://<服务器IP>:%s%s\n' "$c_dim" "${port:-?}" "$c_reset"
}

# --- actions ---
panel_start()   { systemctl start   "$UNIT_NAME" && echo "${c_g}已启动${c_reset}" || echo "${c_r}启动失败${c_reset}"; }
panel_stop()    { systemctl stop    "$UNIT_NAME" && echo "${c_g}已停止${c_reset}" || echo "${c_r}停止失败${c_reset}"; }
panel_restart() { systemctl restart "$UNIT_NAME" && echo "${c_g}已重启${c_reset}" || echo "${c_r}重启失败${c_reset}"; }

panel_update() {
  local arch current latest url tmp newver
  case "$(uname -m)" in x86_64|amd64) arch=amd64;; aarch64|arm64) arch=arm64;; *) echo "${c_r}不支持的架构${c_reset}"; return;; esac
  current="$([[ -x "$BIN" ]] && "$BIN" -version 2>/dev/null)"
  echo "当前版本: ${current:-未知}，正在查询最新版…"
  latest="$(curl -fsSL -H 'User-Agent: wirenest' "https://api.github.com/repos/${REPO}/releases/latest" 2>/dev/null \
            | sed -n 's/.*"tag_name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)"
  if [[ -n "$latest" && "$latest" == "$current" ]]; then echo "${c_g}已经是最新版本 ${current}${c_reset}"; return; fi
  [[ -n "$latest" ]] && echo "最新版本: $latest"
  url="https://github.com/${REPO}/releases/latest/download/wireguard-ui-linux-${arch}"
  echo "下载中: $url"
  tmp="$(mktemp)"
  if ! curl -fL --retry 3 -o "$tmp" "$url"; then echo "${c_r}下载失败${c_reset}"; rm -f "$tmp"; return; fi
  chmod +x "$tmp"
  if ! newver="$("$tmp" -version 2>/dev/null)"; then echo "${c_r}下载的文件无效，已放弃${c_reset}"; rm -f "$tmp"; return; fi
  install -m755 "$tmp" "$BIN"; rm -f "$tmp"
  systemctl restart "$UNIT_NAME"
  echo "${c_g}已更新: ${current:-?} → ${newver}${c_reset}"
}

change_port() {
  local addr host cur new
  addr="$(get_env WGUI_ADDR)"; host="${addr%:*}"; cur="${addr##*:}"
  read -rp "新端口（当前 ${cur:-8000}，回车不变）: " new
  [[ -z "$new" ]] && { echo "未修改"; return; }
  [[ "$new" =~ ^[0-9]+$ ]] && (( new >= 1 && new <= 65535 )) || { echo "${c_r}端口无效（1-65535）${c_reset}"; return; }
  set_env WGUI_ADDR "${host:-0.0.0.0}:${new}" || { echo "${c_r}单元文件异常，未找到 WGUI_ADDR${c_reset}"; return; }
  systemctl daemon-reload && systemctl restart "$UNIT_NAME"
  echo "${c_g}端口已改为 ${new} 并重启${c_reset}"
  echo "${c_y}提醒: 记得在防火墙/云安全组放行端口 ${new}${c_reset}"
}

reset_password() {
  local p1 p2 user
  read -rsp "新登录密码: " p1; echo
  read -rsp "再次输入确认: " p2; echo
  [[ -z "$p1" ]] && { echo "${c_r}密码不能为空${c_reset}"; return; }
  [[ "$p1" == "$p2" ]] || { echo "${c_r}两次输入不一致${c_reset}"; return; }
  case "$p1" in *[\ \"]*) echo "${c_r}密码请勿包含空格或双引号${c_reset}"; return;; esac
  # 保留已在面板里改过的用户名（若有 credentials.json）。
  if [[ -f "$DATA_DIR/credentials.json" ]]; then
    user="$(sed -n 's/.*"username"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$DATA_DIR/credentials.json" | head -1)"
    [[ -n "$user" ]] && set_env WGUI_ADMIN_USER "$user"
  fi
  set_env WGUI_ADMIN_PASS "$p1" || { echo "${c_r}单元文件异常，未找到 WGUI_ADMIN_PASS${c_reset}"; return; }
  rm -f "$DATA_DIR/credentials.json"          # 让 env 里的新密码重新生效
  systemctl daemon-reload && systemctl restart "$UNIT_NAME"
  echo "${c_g}密码已重置，登录用户名: $(get_env WGUI_ADMIN_USER)${c_reset}"
}

menu() {
  while true; do
    clear 2>/dev/null
    echo "======================================"
    print_status
    echo "======================================"
    echo "  1) 启动面板"
    echo "  2) 停止面板"
    echo "  3) 重启面板"
    echo "  4) 更新面板到最新版"
    echo "  5) 更换运行端口"
    echo "  6) 重置登录密码"
    echo "  0) 退出"
    echo "--------------------------------------"
    read -rp "请选择 [0-6]: " choice
    echo
    case "$choice" in
      1) panel_start; pause ;;
      2) panel_stop; pause ;;
      3) panel_restart; pause ;;
      4) panel_update; pause ;;
      5) change_port; pause ;;
      6) reset_password; pause ;;
      0) exit 0 ;;
      *) echo "无效选择"; sleep 1 ;;
    esac
  done
}

need_root
[[ -f "$UNIT" ]] || { echo "${c_r}未找到 $UNIT，请先安装 WireNest${c_reset}" >&2; exit 1; }

# 直接子命令（便于脚本化），否则进入交互菜单。
case "${1:-}" in
  start)   panel_start ;;
  stop)    panel_stop ;;
  restart) panel_restart ;;
  update)  panel_update ;;
  status)  print_status ;;
  ""|menu) menu ;;
  *) echo "用法: wirenest [start|stop|restart|update|status]（无参数进入菜单）" ;;
esac
